<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:background="@color/bg_surface">

        <Button
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="&#8592;"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:background="@android:color/transparent"
            android:stateListAnimator="@null"
            android:padding="0dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BEAT EDITOR"
            android:textSize="17sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.15"
            android:gravity="center"/>

        <Button
            android:id="@+id/saveButton"
            android:layout_width="64dp"
            android:layout_height="38dp"
            android:text="SAVE"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_btn_secondary"
            android:stateListAnimator="@null"
            android:padding="0dp"/>

    </LinearLayout>

    <!-- BPM Control -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_card"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPM"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/bpmMinus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="&#8722;"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_btn_secondary"
            android:stateListAnimator="@null"
            android:padding="0dp"/>

        <TextView
            android:id="@+id/bpmDisplay"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="120"
            android:textSize="30sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-black"
            android:gravity="center"/>

        <Button
            android:id="@+id/bpmPlus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="+"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_btn_secondary"
            android:stateListAnimator="@null"
            android:padding="0dp"/>

    </LinearLayout>

    <!-- Instrument Rows -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- KICK -->
            <LinearLayout
                android:id="@+id/kickCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/kickLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="KICK"
                        android:textColor="@color/accent_purple"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"
                        android:padding="4dp"/>

                    <Button
                        android:id="@+id/kickMute"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="M"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/kickToggle"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="8"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/kickRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

                <SeekBar
                    android:id="@+id/kickVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="@color/accent_purple"
                    android:thumbTint="@color/accent_purple"
                    android:progressBackgroundTint="@color/step_inactive"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="L"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                    <SeekBar
                        android:id="@+id/kickPan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="200"
                        android:progress="100"
                        android:progressTint="@color/text_muted"
                        android:thumbTint="@color/accent_purple"
                        android:progressBackgroundTint="@color/step_inactive"/>

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

            <!-- SNARE -->
            <LinearLayout
                android:id="@+id/snareCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/snareLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SNARE"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"
                        android:padding="4dp"/>

                    <Button
                        android:id="@+id/snareMute"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="M"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/snareToggle"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="8"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/snareRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

                <SeekBar
                    android:id="@+id/snareVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="@color/accent_cyan"
                    android:thumbTint="@color/accent_cyan"
                    android:progressBackgroundTint="@color/step_inactive"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="L"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                    <SeekBar
                        android:id="@+id/snarePan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="200"
                        android:progress="100"
                        android:progressTint="@color/text_muted"
                        android:thumbTint="@color/accent_cyan"
                        android:progressBackgroundTint="@color/step_inactive"/>

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

            <!-- HI-HAT -->
            <LinearLayout
                android:id="@+id/hatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/hatLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="HI-HAT"
                        android:textColor="@color/accent_amber"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"
                        android:padding="4dp"/>

                    <Button
                        android:id="@+id/hatMute"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="M"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/hatToggle"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="8"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/hatRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

                <SeekBar
                    android:id="@+id/hatVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="@color/accent_amber"
                    android:thumbTint="@color/accent_amber"
                    android:progressBackgroundTint="@color/step_inactive"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="L"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                    <SeekBar
                        android:id="@+id/hatPan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="200"
                        android:progress="100"
                        android:progressTint="@color/text_muted"
                        android:thumbTint="@color/accent_amber"
                        android:progressBackgroundTint="@color/step_inactive"/>

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

            <!-- OPEN HAT -->
            <LinearLayout
                android:id="@+id/openHatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/openHatLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="OPEN HAT"
                        android:textColor="@color/accent_green"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"
                        android:padding="4dp"/>

                    <Button
                        android:id="@+id/openHatMute"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="M"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/openHatToggle"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="8"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/openHatRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

                <SeekBar
                    android:id="@+id/openHatVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="@color/accent_green"
                    android:thumbTint="@color/accent_green"
                    android:progressBackgroundTint="@color/step_inactive"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="L"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                    <SeekBar
                        android:id="@+id/openHatPan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="200"
                        android:progress="100"
                        android:progressTint="@color/text_muted"
                        android:thumbTint="@color/accent_green"
                        android:progressBackgroundTint="@color/step_inactive"/>

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

            <!-- CLAP -->
            <LinearLayout
                android:id="@+id/clapCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/clapLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CLAP"
                        android:textColor="@color/accent_purple"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"
                        android:padding="4dp"/>

                    <Button
                        android:id="@+id/clapMute"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="M"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/clapToggle"
                        android:layout_width="36dp"
                        android:layout_height="30dp"
                        android:text="8"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_btn_secondary"
                        android:stateListAnimator="@null"
                        android:padding="0dp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/clapRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

                <SeekBar
                    android:id="@+id/clapVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="@color/accent_purple"
                    android:thumbTint="@color/accent_purple"
                    android:progressBackgroundTint="@color/step_inactive"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="L"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                    <SeekBar
                        android:id="@+id/clapPan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="200"
                        android:progress="100"
                        android:progressTint="@color/text_muted"
                        android:thumbTint="@color/accent_purple"
                        android:progressBackgroundTint="@color/step_inactive"/>

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Play Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:gravity="center"
        android:background="@color/bg_surface">

        <Button
            android:id="@+id/reverbButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="FX"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_btn_secondary"
            android:stateListAnimator="@null"
            android:padding="0dp"
            android:layout_marginEnd="20dp"/>

        <Button
            android:id="@+id/playButton"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="&#9654;"
            android:textSize="26sp"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/bg_play_btn"
            android:stateListAnimator="@null"
            android:padding="0dp"/>

        <Button
            android:id="@+id/eqButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="EQ"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_btn_secondary"
            android:stateListAnimator="@null"
            android:padding="0dp"
            android:layout_marginStart="20dp"/>

    </LinearLayout>

</LinearLayout>
