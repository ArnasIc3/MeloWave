<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp">

    <!-- Timeline column -->
    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="top|center_horizontal">

        <View
            android:layout_width="2dp"
            android:layout_height="10dp"
            android:background="@color/divider"/>

        <TextView
            android:id="@+id/barNumber"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@color/accent_cyan"
            android:fontFamily="sans-serif-black"
            android:background="@drawable/bg_btn_secondary"/>

        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/divider"/>

    </LinearLayout>

    <!-- Pattern block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="12dp"
        android:layout_marginStart="8dp">

        <!-- Header row: drag handle + name + remove button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/dragHandle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x283F;"
                android:textSize="18sp"
                android:textColor="@color/text_muted"
                android:paddingEnd="10dp"
                android:paddingStart="0dp"/>

            <TextView
                android:id="@+id/patternName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pattern"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:maxLines="1"/>

            <Button
                android:id="@+id/removeBarBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="&#215;"
                android:textSize="16sp"
                android:textColor="@color/button_danger"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null"
                android:padding="0dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/patternMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="2dp"/>

        <!-- Step preview (filled programmatically) -->
        <LinearLayout
            android:id="@+id/stepPreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
